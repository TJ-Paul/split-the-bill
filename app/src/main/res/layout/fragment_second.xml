<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    android:padding="16dp"
    tools:context=".SecondFragment">

    <TextView
        android:id="@+id/tvReceiptHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:drawablePadding="8dp"
        android:letterSpacing="0.02"
        android:text="🧾 Receipt Summary"
        android:textAppearance="@style/TextAppearance.App.SectionTitle"
        android:textSize="22sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvRestaurantName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_pill_secondary"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp"
        android:textColor="@color/color_secondary_dark"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvReceiptHeader"
        tools:text="Nando's" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardReceipt"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        app:cardBackgroundColor="@color/color_surface"
        app:cardCornerRadius="16dp"
        app:cardElevation="1dp"
        app:strokeColor="@color/color_outline"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toTopOf="@id/btnSaveLog"
        app:layout_constraintTop_toBottomOf="@id/tvRestaurantName">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/tvReceiptDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="18dp"
                android:fontFamily="monospace"
                android:lineSpacingExtra="5dp"
                android:textColor="@color/color_on_surface"
                android:textSize="13sp"
                tools:text="Details..." />
        </androidx.core.widget.NestedScrollView>

    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSaveLog"
        style="@style/Widget.App.Button.Outlined"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="Save Copy to App Log"
        android:textAllCaps="false"
        app:icon="@android:drawable/ic_menu_save"
        app:iconGravity="textStart"
        app:layout_constraintBottom_toTopOf="@id/btnBack" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBack"
        style="@style/Widget.App.Button.Filled"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="Back to Orders"
        android:textAllCaps="false"
        app:icon="@android:drawable/ic_media_previous"
        app:iconGravity="textStart"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>